{
  "name": "metalflow",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run validate:deploy",
    "build:analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "validate:deploy": "node scripts/postDeploy.js",
    "deploy:cloudflare": "npm run build && wrangler pages deploy dist",
    "deploy:cloudflare:preview": "npm run build && wrangler pages deploy dist --branch preview"
  },
  "dependencies": {
    "dxf": "^5.3.1",
    "dxf-parser": "^1.1.2",
    "framer-motion": "^12.38.0",
    "html2pdf.js": "^0.14.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.8.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260509.1",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "terser": "^5.47.1",
    "vite": "^5.0.2",
    "wrangler": "^4.90.0"
  }
}
